# =====================================================
# IGC SALAS - Variáveis de Ambiente
# Instituto de Geociências - Sistema de Gestão de Salas
# =====================================================

# Django
SECRET_KEY=igc-salas-super-secret-key-change-in-production-2025
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0

# Banco de Dados PostgreSQL
POSTGRES_DB=igc_salas_db
POSTGRES_USER=igc_admin
POSTGRES_PASSWORD=igc_salas_secure_pass_2025
POSTGRES_HOST=db
POSTGRES_PORT=5432
DATABASE_URL=postgres://igc_admin:igc_salas_secure_pass_2025@db:5432/igc_salas_db

# Redis (Cache e Celery)
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1

# Email (SMTP)
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=igc.salas@igc.ufmg.br
EMAIL_HOST_PASSWORD=sua-senha-de-app-aqui
DEFAULT_FROM_EMAIL=IGC Salas <igc.salas@igc.ufmg.br>

# Aplicação
SITE_NAME=IGC Salas
SITE_URL=http://localhost
TIMEZONE=America/Sao_Paulo
LANGUAGE_CODE=pt-br

# Gunicorn
GUNICORN_WORKERS=4
GUNICORN_TIMEOUT=120
